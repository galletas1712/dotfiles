{ config, pkgs, lib, inputs, username, ... }:

{
  imports = [ "${inputs.agent-config}/module.nix" ];
  home.username = username;
  home.homeDirectory = "/home/${username}";
  home.stateVersion = "25.11";

  home.packages = with pkgs; [
    # Languages & runtimes
    nodejs
    go
    gopls
    zig
    bun
    uv
    rustup
    python3

    # Build tools
    gcc
    # Lower priority to avoid bin/cc conflict with gcc
    (lib.setPrio 20 clang)
    llvmPackages.llvm
    gnumake
    cmake
    ninja
    ccache
    pkg-config
    protobuf

    # CLI tools
    just
    ripgrep
    jq
    gh
    chezmoi
    tmux
    htop
    vim
    neovim
    fzf
{{- if eq .chezmoi.os "darwin" }}
    ffmpeg
    yt-dlp
{{- end }}

    # Kubernetes
    kubectl
    k9s
    kubernetes-helm
    kind
    minikube
    kubebuilder
    kubelogin

{{- if eq .chezmoi.os "linux" }}
    # Debugging (linux-only)
    gdb
    strace
    criu
{{- end }}

    # Networking
    nmap
    tcpdump
    socat
    mosh
    eternal-terminal

    # Servers
    etcd
    nats-server
  ];

  programs.starship = {
    enable = true;
    settings = {
      command_timeout = 750;
      format = "$env_var$username$hostname $character$directory";
      right_format = "$all";
      conda.format = "[$symbol$environment]($style)";
      python.format = "[\${symbol}\${pyenv_prefix}(\${version} )(\\($virtualenv\\) )]($style)";
      username = {
        format = "[$user]($style)";
        style_user = "bold green";
        style_root = "bold red";
        show_always = true;
      };
      hostname = {
        format = "[@$hostname]($style)";
        style = "bold yellow";
      };
      env_var.ZMX_SESSION = {
        format = "[$env_value]($style) ";
        style = "bold cyan";
      };
      directory.truncate_to_repo = true;
    };
  };

  programs.yazi = {
    enable = true;
    settings = {
      preview = {
        max_width = 2048;
        max_height = 2048;
        image_quality = 60;
        wrap = "yes";
        tab_size = 2;
      };
      manager = {
        ratio = [ 1 2 2 ];
        show_hidden = true;
        sort_by = "mtime";
        sort_reverse = true;
      };
    };
  };

  programs.git = {
    enable = true;
    signing.signByDefault = true;
    settings = {
      user.name = "Schwinn Saereesitthipitak";
      user.email = "schwinns@nvidia.com";
      init.defaultBranch = "main";
    };
    includes = [{
      path = toString (pkgs.writeText "gh-credential.gitconfig" ''
        [credential "https://github.com"]
        	helper =
        	helper = !${pkgs.gh}/bin/gh auth git-credential
        [credential "https://gist.github.com"]
        	helper =
        	helper = !${pkgs.gh}/bin/gh auth git-credential
      '');
    }];
  };

  home.sessionVariables = {
    EDITOR = "vim";
  };

  agentConfig.enable = true;

  programs.home-manager.enable = true;
}
