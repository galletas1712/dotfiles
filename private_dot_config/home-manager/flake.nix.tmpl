{
  description = "System configuration of {{ .chezmoi.username }}";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs/nixos-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
{{- if eq .chezmoi.os "darwin" }}
    nix-darwin = {
      url = "github:LnL7/nix-darwin/master";
      inputs.nixpkgs.follows = "nixpkgs";
    };
{{- end }}
    claude-code-nix = {
      url = "github:sadjow/claude-code-nix";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    codex = {
      url = "github:galletas1712/codex/dev";
    };
{{- if eq .chezmoi.os "linux" }}
    zmx = {
      url = "github:neurosnap/zmx";
    };
    cuda-checkpoint-src = {
      url = "github:NVIDIA/cuda-checkpoint";
      flake = false;
    };
{{- end }}
    agent-config = {
      url = "path:{{ .chezmoi.homeDir }}/agent-config";
      flake = false;
    };
  };

  outputs =
    { nixpkgs, home-manager, ... }@inputs:
    let
      system = "{{ if eq .chezmoi.arch "amd64" }}x86_64{{ else }}aarch64{{ end }}-{{ .chezmoi.os }}";
      extraPackagesModule = { ... }: {
        home.packages = [
          inputs.claude-code-nix.packages.${system}.default
          inputs.codex.packages.${system}.default
        ];
      };
    in
    {
{{- if eq .chezmoi.os "darwin" }}
      darwinConfigurations."default" = inputs.nix-darwin.lib.darwinSystem {
        modules = [
          ./darwin.nix
          inputs.home-manager.darwinModules.home-manager
          {
            nixpkgs.hostPlatform = system;
            home-manager.useGlobalPkgs = true;
            home-manager.useUserPackages = true;
            home-manager.extraSpecialArgs = { inherit inputs; };
            home-manager.users."{{ .chezmoi.username }}" = {
              imports = [ ./home.nix extraPackagesModule ];
              home.homeDirectory = nixpkgs.lib.mkForce "{{ .chezmoi.homeDir }}";
            };
          }
        ];
      };
{{- else }}
      homeConfigurations."default" = home-manager.lib.homeManagerConfiguration {
        pkgs = nixpkgs.legacyPackages.${system};
        extraSpecialArgs = { inherit inputs; };
        modules = [
          ./home.nix
          extraPackagesModule
          ({ pkgs, ... }: {
            home.packages = [
              inputs.zmx.packages.${system}.default
              (pkgs.stdenv.mkDerivation {
                pname = "cuda-checkpoint";
                version = "unstable";
                src = inputs.cuda-checkpoint-src;
                dontBuild = true;
                installPhase = ''
                  mkdir -p $out/bin
                  cp bin/x86_64_Linux/cuda-checkpoint $out/bin/
                  chmod +x $out/bin/cuda-checkpoint
                '';
              })
            ];
          })
        ];
      };
{{- end }}
    };
}
