{
  description = "System configuration of {{ .chezmoi.username }}";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs/nixos-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
{{- if eq .chezmoi.os "darwin" }}
    nix-darwin = {
      url = "github:LnL7/nix-darwin/master";
      inputs.nixpkgs.follows = "nixpkgs";
    };
{{- end }}
    claude-code-nix = {
      url = "github:sadjow/claude-code-nix";
      inputs.nixpkgs.follows = "nixpkgs";
    };
{{- if eq .chezmoi.os "linux" }}
    codex-src = {
      url = "https://github.com/openai/codex/releases/download/rust-v0.117.0/codex-x86_64-unknown-linux-gnu.tar.gz";
      flake = false;
    };
    brev-src = {
      url = "https://github.com/brevdev/brev-cli/releases/download/v0.6.322/brev-cli_0.6.322_linux_amd64.tar.gz";
      flake = false;
    };
    zmx = {
      url = "github:neurosnap/zmx";
    };
    cuda-checkpoint-src = {
      url = "github:NVIDIA/cuda-checkpoint";
      flake = false;
    };
{{- else }}
    codex-src = {
      url = "https://github.com/openai/codex/releases/download/rust-v0.117.0/codex-aarch64-apple-darwin.tar.gz";
      flake = false;
    };
    brev-src = {
      url = "https://github.com/brevdev/brev-cli/releases/download/v0.6.322/brev-cli_0.6.322_darwin_arm64.tar.gz";
      flake = false;
    };
{{- end }}
};

  outputs =
    { nixpkgs, home-manager, ... }@inputs:
    let
      system = "{{ if eq .chezmoi.arch "amd64" }}x86_64{{ else }}aarch64{{ end }}-{{ .chezmoi.os }}";
      username = "{{ .chezmoi.username }}";
      codexBin = {{ if eq .chezmoi.os "linux" }}"codex-x86_64-unknown-linux-gnu"{{ else }}"codex-aarch64-apple-darwin"{{ end }};
      extraPackagesModule = { pkgs, ... }: {
        home.packages = [
          inputs.claude-code-nix.packages.${system}.default
          (pkgs.stdenv.mkDerivation {
            pname = "codex";
            version = "0.117.0";
            src = inputs.codex-src;
            dontBuild = true;
            installPhase = ''
              mkdir -p $out/bin
              cp ${codexBin} $out/bin/codex
              chmod +x $out/bin/codex
            '';
          })
          (pkgs.stdenv.mkDerivation {
            pname = "brev";
            version = "0.6.322";
            src = inputs.brev-src;
            dontBuild = true;
            installPhase = ''
              mkdir -p $out/bin
              cp brev $out/bin/
              chmod +x $out/bin/brev
            '';
          })
        ];
      };
    in
    {
{{- if eq .chezmoi.os "darwin" }}
      darwinConfigurations."default" = inputs.nix-darwin.lib.darwinSystem {
        modules = [
          ./darwin.nix
          inputs.home-manager.darwinModules.home-manager
          {
            nixpkgs.hostPlatform = system;
            home-manager.useGlobalPkgs = true;
            home-manager.useUserPackages = true;
            home-manager.extraSpecialArgs = { inherit inputs username; };
            home-manager.users."{{ .chezmoi.username }}" = {
              imports = [
                ./home.nix
                extraPackagesModule
              ];
              home.homeDirectory = nixpkgs.lib.mkForce "{{ .chezmoi.homeDir }}";
            };
          }
        ];
      };
{{- else }}
      homeConfigurations.${username} = home-manager.lib.homeManagerConfiguration {
        pkgs = nixpkgs.legacyPackages.${system};
        extraSpecialArgs = { inherit inputs username; };
        modules = [
          ./home.nix
          extraPackagesModule
          ({ pkgs, ... }: {
            home.packages = [
              inputs.zmx.packages.${system}.default
              (pkgs.stdenv.mkDerivation {
                pname = "cuda-checkpoint";
                version = "unstable";
                src = inputs.cuda-checkpoint-src;
                dontBuild = true;
                installPhase = ''
                  mkdir -p $out/bin
                  cp bin/x86_64_Linux/cuda-checkpoint $out/bin/
                  chmod +x $out/bin/cuda-checkpoint
                '';
              })
            ];
          })
        ];
      };
{{- end }}
    };
}
