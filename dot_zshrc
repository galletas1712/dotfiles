export EDITOR=vim

# Nix (must come first so nix-managed tools are on PATH)
if [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
  . "$HOME/.nix-profile/etc/profile.d/nix.sh"
fi

# Self-managed tools
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/snap/bin:$PATH"
export PATH="$HOME/.docker/bin:$PATH"

# Starship
eval "$(starship init zsh)"

# zmx
eval "$(zmx completions zsh)"
alias za="zmx attach"
alias zl="zmx list"
alias zk="zmx kill"

# nix home-manager
alias nu="nix flake update --flake ~/.config/home-manager && home-manager switch --flake ~/.config/home-manager"
alias ns="home-manager switch --flake ~/.config/home-manager"
