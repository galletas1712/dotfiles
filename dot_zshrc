export EDITOR=vim

# Add entries to PATH
export PATH="$HOME/snap/bin:$PATH"
export PATH="$HOME/.docker/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/bin:$PATH"

export MISE_RUSTUP_HOME="$HOME/.local/share/mise/rustup"
export MISE_CARGO_HOME="$HOME/.local/share/mise/cargo"

# Activate mise before tools referenced later in this file.
if [ -x "$HOME/.local/bin/mise" ]; then
  eval "$("$HOME/.local/bin/mise" activate zsh)"
fi

# Starship
eval "$(starship init zsh)"

# zmx
eval "$(zmx completions zsh)"
alias za="zmx attach"
alias zl="zmx list"
alias zk="zmx kill"
